# HonorCard API 环境变量（复制为 .env 后填入）

PORT=8788
JWT_SECRET=change-me-in-production
OPS_API_KEY=honorcard-ops-dev

# 站点 URL（支付回调 / 跳转）
PUBLIC_URL=http://127.0.0.1:8788
PUBLIC_WEB_URL=http://127.0.0.1:8787

# 设为 0 且配置下方凭证后关闭 demo 模式
PAYMENT_DEMO=1

# —— 微信支付 Native（v3）——
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_V3_KEY=
# WECHAT_MCH_SERIAL=
# WECHAT_PRIVATE_KEY_PATH=

# —— 支付宝电脑网站支付 ——
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
