.page { padding: 40rpx 28rpx; background: #f5efe3; min-height: 100vh; box-sizing: border-box; }
.tip {
  font-size: 26rpx; color: #6b563a; line-height: 1.6;
  background: #fff8e8; border: 1rpx solid #e8d3ad; border-radius: 16rpx;
  padding: 20rpx 24rpx; margin-bottom: 28rpx;
}
.btn.primary { background: #8e1c22; color: #fff; border-radius: 16rpx; font-size: 30rpx; font-weight: 600; }
