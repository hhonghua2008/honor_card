.page { min-height: 100vh; background: #f5efe3; padding-bottom: 32rpx; }
.hero { padding: 28rpx 24rpx 12rpx; text-align: center; }
.title { display: block; font-size: 40rpx; font-weight: 700; color: #8e1c22; }
.sub { display: block; font-size: 24rpx; color: #6b563a; margin-top: 8rpx; line-height: 1.5; }
.toolbar { padding: 8rpx 24rpx 12rpx; }
.search {
  background: #fff; border-radius: 999rpx; padding: 18rpx 28rpx; font-size: 26rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,.05);
}
.filters { white-space: nowrap; width: 100%; }
.filters-sub { margin-top: 8rpx; }
.filter-row { display: inline-flex; padding: 0 16rpx 8rpx; gap: 12rpx; }
.chip {
  display: inline-block; padding: 10rpx 20rpx; border-radius: 999rpx; font-size: 22rpx;
  background: #fff; color: #6b563a; border: 1rpx solid #e8d3ad;
}
.chip.active { background: #8e1c22; color: #fff; border-color: #8e1c22; }
.hint { padding: 0 24rpx 8rpx; font-size: 22rpx; color: #9a7b3f; }
.hint.empty { text-align: center; padding: 24rpx; }
.grid { display: flex; flex-wrap: wrap; padding: 8rpx 12rpx; }
.card {
  width: 46%; margin: 2%; background: #fff; border-radius: 16rpx; overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,.06);
}
.thumb-wrap { position: relative; width: 100%; height: 220rpx; background: #f4e9d8; }
.thumb-wrap.land { height: 160rpx; }
.thumb { width: 100%; height: 100%; display: block; }
.badge {
  position: absolute; top: 8rpx; right: 8rpx; font-size: 18rpx; padding: 4rpx 10rpx;
  border-radius: 8rpx; background: rgba(142,28,34,.85); color: #fff;
}
.name { display: block; font-size: 28rpx; font-weight: 600; padding: 12rpx 16rpx 0; color: #3a2a12; }
.cat { display: block; font-size: 22rpx; color: #9a7b3f; padding: 4rpx 16rpx 16rpx; }
.loading { text-align: center; color: #999; padding: 24rpx; }
