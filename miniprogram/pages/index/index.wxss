.hero { padding: 32rpx 24rpx 16rpx; text-align: center; }
.title { display: block; font-size: 40rpx; font-weight: 700; color: #8e1c22; }
.sub { display: block; font-size: 26rpx; color: #6b563a; margin-top: 8rpx; }
.actions { padding: 0 24rpx 16rpx; }
.btn-pro { background: #8e1c22; color: #fff; font-size: 28rpx; border-radius: 12rpx; }
.grid { display: flex; flex-wrap: wrap; padding: 12rpx; }
.card { width: 46%; margin: 2%; background: #fff; border-radius: 16rpx; padding: 20rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.06); }
.thumb { width: 100%; height: 160rpx; background: linear-gradient(135deg,#f4e9d8,#e8c98a); border-radius: 12rpx; display: flex; align-items: center; justify-content: center; font-size: 48rpx; color: #8e1c22; font-weight: bold; }
.name { display: block; font-size: 28rpx; font-weight: 600; margin-top: 12rpx; color: #3a2a12; }
.cat { display: block; font-size: 22rpx; color: #9a7b3f; margin-top: 4rpx; }
.loading { text-align: center; color: #999; padding: 24rpx; }
