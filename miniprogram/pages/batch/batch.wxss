.page { padding: 28rpx; background: #f5efe3; min-height: 100vh; box-sizing: border-box; }
.tip {
  font-size: 24rpx; color: #6b563a; line-height: 1.55;
  background: #fff8e8; border: 1rpx solid #e8d3ad; border-radius: 14rpx;
  padding: 18rpx 22rpx; margin-bottom: 24rpx;
}
.card {
  background: #fff; border-radius: 16rpx; padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,.04);
}
.label { display: block; font-size: 24rpx; color: #9a7b3f; margin-bottom: 10rpx; }
.area {
  width: 100%; min-height: 360rpx; background: #faf6ee; border-radius: 12rpx;
  padding: 16rpx; font-size: 28rpx; color: #3a2a12; box-sizing: border-box;
}
.prog { margin: 20rpx 0; font-size: 26rpx; color: #8e1c22; text-align: center; }
.btn.primary {
  margin-top: 28rpx; background: #8e1c22; color: #fff; border-radius: 16rpx;
  font-size: 30rpx; font-weight: 600;
}
.btn[disabled] { opacity: 0.55; }
.hidden-canvas { position: fixed; left: -9999px; top: -9999px; opacity: 0; }
