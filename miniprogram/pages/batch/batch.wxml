<view class="page">
  <view class="tip">{{tip}}</view>
  <view class="card">
    <text class="label">模板：{{tplName}}</text>
    <text class="label">名单（{{nameCount}} 人）</text>
    <textarea
      class="area"
      placeholder="张小明&#10;李华&#10;王芳"
      value="{{namesText}}"
      bindinput="onNames"
      maxlength="5000"
    />
  </view>
  <view class="prog" wx:if="{{progress}}">{{progress}}</view>
  <button class="btn primary" bindtap="startBatch" disabled="{{running}}">
    {{running ? '生成中…' : '开始批量保存到相册'}}
  </button>
  <!-- 离屏降级用隐藏画布 -->
  <canvas type="2d" id="batchCanvas" class="hidden-canvas" style="width:{{1}}px;height:{{1}}px;"></canvas>
</view>
