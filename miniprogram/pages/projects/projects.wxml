<view class="page">
  <view class="cloud-bar">
    <text class="cloud-tip">{{cloudTip}}</text>
    <view class="cloud-btns">
      <button size="mini" class="cbtn" wx:if="{{cloudOn}}" bindtap="syncUp">上传云端</button>
      <button size="mini" class="cbtn" wx:if="{{cloudOn}}" bindtap="syncDown">拉取云端</button>
      <button size="mini" class="cbtn ghost" bindtap="exportBackup">导出备份</button>
      <button size="mini" class="cbtn ghost" bindtap="importBackup">导入备份</button>
    </view>
  </view>

  <view wx:if="{{empty}}" class="empty">
    <text class="t">还没有草稿</text>
    <text class="s">在模板页选一套，编辑后点「保存」</text>
    <button class="btn primary" bindtap="goTemplates">去选模板</button>
  </view>

  <view wx:else class="list">
    <view class="item" wx:for="{{list}}" wx:key="id">
      <view class="main" bindtap="open" data-id="{{item.id}}">
        <image class="thumb" src="{{item.thumb}}" mode="aspectFill" />
        <view class="meta">
          <text class="name">{{item.name}}</text>
          <text class="sub">{{item.tplName}} · {{item.updatedText}}</text>
        </view>
      </view>
      <text class="del" catchtap="remove" data-id="{{item.id}}">删除</text>
    </view>
  </view>
</view>
