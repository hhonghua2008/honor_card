<view class="page">
  <view class="preview-wrap">
    <canvas type="2d" id="certCanvas" class="canvas" style="{{canvasStyle}}"></canvas>
    <view wx:if="{{rendering}}" class="preview-mask">绘制中…</view>
  </view>

  <view class="tip">{{tip}}</view>

  <view class="form">
    <view class="row" wx:if="{{hasPhoto}}">
      <text class="label">照片</text>
      <view class="photo-actions">
        <button size="mini" class="mini" bindtap="choosePhoto">{{photoPath ? '更换照片' : '上传照片'}}</button>
        <button size="mini" class="mini ghost" wx:if="{{photoPath}}" bindtap="clearPhoto">清除</button>
      </view>
    </view>

    <view class="row">
      <text class="label">标题</text>
      <input class="input" data-key="title" value="{{fields.title}}" bindinput="onField" />
    </view>
    <view class="row" wx:if="{{hasLabel}}">
      <text class="label">称呼前缀（如：兹证明 / 亲爱的）</text>
      <input class="input" data-key="label" value="{{fields.label}}" bindinput="onField" />
    </view>
    <view class="row twin">
      <view class="half">
        <text class="label">姓名</text>
        <input class="input" data-key="name" value="{{fields.name}}" bindinput="onField" />
      </view>
      <view class="half">
        <text class="label">称呼</text>
        <input class="input" data-key="suffix" value="{{fields.suffix}}" bindinput="onField" placeholder="同学" />
      </view>
    </view>
    <view class="row">
      <text class="label">荣誉称号</text>
      <input class="input" data-key="honor" value="{{fields.honor}}" bindinput="onField" placeholder="可留空" />
    </view>
    <view class="row">
      <text class="label">正文</text>
      <textarea class="textarea" data-key="reason" value="{{fields.reason}}" bindinput="onField" auto-height maxlength="200" />
    </view>
    <view class="row">
      <text class="label">结束语</text>
      <textarea class="textarea" data-key="closing" value="{{fields.closing}}" bindinput="onField" auto-height maxlength="80" />
    </view>
    <view class="row twin">
      <view class="half">
        <text class="label">颁发单位</text>
        <input class="input" data-key="issuer" value="{{fields.issuer}}" bindinput="onField" />
      </view>
      <view class="half">
        <text class="label">日期</text>
        <input class="input" data-key="date" value="{{fields.date}}" bindinput="onField" />
      </view>
    </view>
    <view class="row">
      <text class="label">印章文字</text>
      <input class="input" data-key="sealText" value="{{fields.sealText}}" bindinput="onField" maxlength="10" />
    </view>
  </view>

  <view class="actions actions-3">
    <button class="btn ghost" bindtap="saveProject">保存</button>
    <button class="btn ghost" bindtap="goBatch">批量</button>
    <button class="btn primary" bindtap="exportImage">导出</button>
  </view>
</view>
