.page { padding: 32rpx 28rpx 48rpx; background: #f5efe3; min-height: 100vh; box-sizing: border-box; }
.card {
  background: #fff; border-radius: 20rpx; overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,.06); margin-bottom: 28rpx;
}
.thumb { width: 100%; height: 360rpx; display: block; background: #f4e9d8; }
.meta { padding: 24rpx; }
.name { display: block; font-size: 34rpx; font-weight: 700; color: #3a2a12; }
.cat { display: block; margin-top: 8rpx; font-size: 24rpx; color: #9a7b3f; }
.tip {
  font-size: 26rpx; color: #6b563a; line-height: 1.6;
  background: #fff8e8; border: 1rpx solid #e8d3ad; border-radius: 16rpx;
  padding: 20rpx 24rpx; margin-bottom: 28rpx;
}
.btn {
  margin-bottom: 20rpx; border-radius: 16rpx; font-size: 30rpx; font-weight: 600;
}
.btn.primary { background: #8e1c22; color: #fff; }
.btn.ghost { background: #fff; color: #8e1c22; border: 1rpx solid #e8d3ad; }
.help {
  margin-top: 24rpx; padding: 24rpx; background: #fff; border-radius: 16rpx;
  display: flex; flex-direction: column; gap: 10rpx;
}
.help text { font-size: 24rpx; color: #6b563a; line-height: 1.5; }
.help .h { font-size: 28rpx; font-weight: 700; color: #3a2a12; margin-bottom: 6rpx; }
