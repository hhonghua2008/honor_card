.page { padding: 20rpx 24rpx 48rpx; background: #f5efe3; min-height: 100vh; box-sizing: border-box; }
.preview-wrap {
  position: relative; background: #fff; border-radius: 16rpx; margin: 0 auto;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,.06); overflow: hidden;
}
.thumb-placeholder {
  position: absolute; left: 0; top: 0; width: 100%; height: 100%;
  display: block; z-index: 1; background: #f4e9d8;
}
.canvas { display: block; position: relative; z-index: 2; background: transparent; }
.preview-mask {
  position: absolute; left: 0; right: 0; bottom: 0; z-index: 3;
  background: rgba(58,42,18,.45); color: #fff;
  padding: 12rpx; text-align: center; font-size: 22rpx;
}
.tabs {
  display: flex; margin: 16rpx 0 8rpx; background: #fff; border-radius: 14rpx;
  overflow: hidden; box-shadow: 0 4rpx 12rpx rgba(0,0,0,.04);
}
.tab {
  flex: 1; text-align: center; padding: 18rpx 8rpx; font-size: 24rpx; color: #6b563a; font-weight: 600;
}
.tab.on { color: #fff; background: #8e1c22; }
.label-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.label-row .label { margin-bottom: 0; }
.pick { font-size: 22rpx; color: #8e1c22; padding: 4rpx 8rpx; }
.hint-box {
  margin-top: 8rpx; padding: 16rpx 18rpx; font-size: 22rpx; color: #6b563a; line-height: 1.55;
  background: #fff8e8; border-radius: 12rpx; border: 1rpx solid #e8d3ad;
}
.form {
  background: #fff; border-radius: 16rpx; padding: 8rpx 20rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,.04);
}
.row { padding: 16rpx 0; border-bottom: 1rpx solid #f0e6d4; }
.row:last-child { border-bottom: none; }
.row.twin { display: flex; gap: 20rpx; }
.half { flex: 1; }
.label { display: block; font-size: 22rpx; color: #9a7b3f; margin-bottom: 8rpx; }
.input {
  background: #faf6ee; border-radius: 12rpx; padding: 14rpx 18rpx; font-size: 28rpx; color: #3a2a12;
}
.textarea {
  width: 100%; min-height: 100rpx; background: #faf6ee; border-radius: 12rpx;
  padding: 14rpx 18rpx; font-size: 28rpx; color: #3a2a12; box-sizing: border-box;
}
.photo-actions { display: flex; gap: 12rpx; }
.mini { background: #8e1c22; color: #fff; }
.mini.ghost { background: #fff; color: #8e1c22; border: 1rpx solid #e8d3ad; }
.actions {
  position: sticky; bottom: 0; display: flex; gap: 12rpx; margin-top: 24rpx;
  padding: 16rpx 0 calc(16rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(245,239,227,0), #f5efe3 30%);
}
.actions-3 .btn { font-size: 28rpx; }
.btn {
  flex: 1; border-radius: 16rpx; font-size: 30rpx; font-weight: 600; padding: 8rpx 0;
}
.btn.primary { background: #8e1c22; color: #fff; }
.btn.ghost { background: #fff; color: #8e1c22; border: 1rpx solid #e8d3ad; }
